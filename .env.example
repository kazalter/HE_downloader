# 复制为 .env 后按需修改。.env 不进 git。

# aria2 RPC 密钥（gateway 与 aria2 共用，务必改成随机串）
ARIA2_RPC_SECRET=change-me-to-a-random-secret

# gateway 对外鉴权 token。留空 = 不鉴权（仅限可信局域网）。
GATEWAY_API_TOKEN=

# 宿主机下载目录，会同时挂进 aria2 和 gateway 的 /downloads。
# ⚠️ 这个目录必须归 PUID:PGID 所属（aria2 以该用户身份写文件），否则下载会
#    "Permission denied"。新目录先执行：sudo chown -R 1000:1000 <目录>
DOWNLOAD_DIR=./downloads

# 媒体库盘，会挂进 aria2 的 /mnt/hdd。Linux 部署通常保持 /mnt/hdd；
# Windows 本地测试脚本会在缺省时自动追加 MEDIA_DIR=./media。
MEDIA_DIR=/mnt/hdd

# 时区 / 权限（p3terx/aria2-pro 用）
TZ=Asia/Shanghai
PUID=1000
PGID=1000

# 宿主机端口
GATEWAY_PORT=8011
ARIA2_RPC_PORT=6800

# 下载代理的默认值。留空 = 直连；也可在下载中心界面里运行时设置。
# 例如 http://127.0.0.1:7897
ARIA2_ALL_PROXY=

# magnet 公共 tracker 补充。留空则使用程序内置默认；设为一个逗号分隔列表可覆盖。
BT_TRACKERS=

# 从 HE 收藏导入（可选）：HE Manager 后端地址 + 一个 HE 的 access token。
# 配上后，下载中心面板顶栏出现「HE 收藏」入口，可勾选 asmr/wnacg 收藏直接下载。
# 留空则不显示该入口。token 取得：在 HE 容器内
#   docker exec he-manager python -c "from app import database,models,auth; db=database.SessionLocal(); print(auth.create_access_token(db, db.query(models.User).filter(models.User.is_active==True).first()))"
HE_MANAGER_URL=
HE_MANAGER_TOKEN=

# 复制为 .env 后按需修改。.env 不进 git。

# aria2 RPC 密钥（gateway 与 aria2 共用，务必改成随机串）
ARIA2_RPC_SECRET=change-me-to-a-random-secret

# gateway 对外鉴权 token。留空 = 不鉴权（仅限可信局域网）。
GATEWAY_API_TOKEN=

# 宿主机下载目录，会同时挂进 aria2 和 gateway 的 /downloads。
# ⚠️ 这个目录必须归 PUID:PGID 所属（aria2 以该用户身份写文件），否则下载会
#    "Permission denied"。新目录先执行：sudo chown -R 1000:1000 <目录>
DOWNLOAD_DIR=./downloads

# 时区 / 权限（p3terx/aria2-pro 用）
TZ=Asia/Shanghai
PUID=1000
PGID=1000

# 宿主机端口
GATEWAY_PORT=8011
ARIA2_RPC_PORT=6800
